<Application x:Class="Hangman.Client.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="Views/Windows/LoginWindow.xaml">
    <Application.Resources>

        <SolidColorBrush x:Key="ColorTexto" Color="#3D2314"/>
        <SolidColorBrush x:Key="ColorMaderaClara" Color="#E5C39C"/>
        <SolidColorBrush x:Key="ColorMaderaBorde" Color="#C79F73"/>
        <SolidColorBrush x:Key="ColorFondoInput" Color="#F8EAD9"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource ColorTexto}"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="45"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="Background" Value="{StaticResource ColorFondoInput}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ColorMaderaBorde}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Foreground" Value="{StaticResource ColorTexto}"/>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Height" Value="45"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="Background" Value="{StaticResource ColorFondoInput}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ColorMaderaBorde}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Foreground" Value="{StaticResource ColorTexto}"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Foreground" Value="{StaticResource ColorTexto}"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="BotonMaderaStyle" TargetType="Button">
            <Setter Property="Background" Value="#E5C39C"/>
            <Setter Property="BorderBrush" Value="#B58B5C"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Foreground" Value="{StaticResource ColorTexto}"/>
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F2D5B5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Application.Resources>
</Application>