<UserControl x:Class="Hangman.Client.Views.UserControls.MatchGameplayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:localization="clr-namespace:Hangman.Client.Localization"
             xmlns:userControls="clr-namespace:Hangman.Client.Views.UserControls"
             Background="Transparent"
             MinWidth="800"
             MinHeight="500">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style x:Key="GameplayCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#F7E7CF"/>
            <Setter Property="BorderBrush" Value="#B58B5C"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="Transparent">
        <Border Width="1250"
                Height="760"
                Background="#FAF3E6"
                BorderBrush="#B58B5C"
                BorderThickness="4"
                CornerRadius="10"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

            <Border BorderBrush="#462A1A"
                    BorderThickness="2"
                    Margin="15,15,15,25">

                <Grid Margin="28">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="{localization:Loc MatchGameplay_Title}"
                               FontSize="34"
                               Foreground="#462A1A"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#8C5A35"
                                              BlurRadius="0"
                                              ShadowDepth="4"
                                              Direction="315"
                                              Opacity="0.7"/>
                        </TextBlock.Effect>
                    </TextBlock>

                    <Border Grid.Row="1"
                            Style="{StaticResource GameplayCardStyle}">

                        <StackPanel>
                            <TextBlock FontSize="17"
                                       Foreground="#462A1A">
                                <Run Text="{localization:Loc Match_HostLabel}"/>
                                <Run Text=": "/>
                                <Run Text="{Binding CurrentLobby.HostFullName}"/>
                                <Run Text="   |   "/>
                                <Run Text="{localization:Loc Match_GuestLabel}"/>
                                <Run Text=": "/>
                                <Run Text="{Binding CurrentLobby.GuestFullName}"/>
                            </TextBlock>

                            <TextBlock FontSize="17"
                                       Foreground="#462A1A"
                                       Margin="0,8,0,0">
                                <Run Text="{localization:Loc MatchGameplay_SelectedCategoryLabel}"/>
                                <Run Text=": "/>
                                <Run Text="{Binding CurrentLobby.SelectedCategoryName}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.1*"/>
                            <ColumnDefinition Width="0.9*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    Margin="0,0,18,0">

                            <Border Style="{StaticResource GameplayCardStyle}"
                                    Visibility="{Binding IsVotingCategory, Converter={StaticResource BooleanToVisibilityConverter}}">

                                <StackPanel>
                                    <TextBlock Text="{localization:Loc MatchGameplay_CategoryVotingTitle}"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               Foreground="#462A1A"
                                               Margin="0,0,0,12"/>

                                    <TextBlock FontSize="17"
                                               Foreground="#462A1A"
                                               Margin="0,0,0,12">
                                        <Run Text="{localization:Loc MatchGameplay_RemainingSecondsLabel}"/>
                                        <Run Text=": "/>
                                        <Run Text="{Binding RemainingVotingSeconds, Mode=OneWay}"/>
                                    </TextBlock>

                                    <TextBlock Text="{localization:Loc MatchGameplay_SelectCategoryLabel}"
                                               FontSize="16"
                                               Foreground="#462A1A"
                                               Margin="0,0,0,8"/>

                                    <ComboBox ItemsSource="{Binding Categories}"
                                              SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                                              DisplayMemberPath="Name"
                                              Height="45"
                                              Style="{StaticResource RetroComboBoxStyle}"
                                              Margin="0,0,0,16"/>

                                    <Button Content="{localization:Loc MatchGameplay_VoteButton}"
                                            Command="{Binding VoteCategoryCommand}"
                                            Width="220"
                                            Height="58"
                                            HorizontalAlignment="Left"
                                            Style="{StaticResource BotonRetroStyle}"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource GameplayCardStyle}"
                                    Visibility="{Binding IsWaitingForHostWord, Converter={StaticResource BooleanToVisibilityConverter}}">

                                <StackPanel>
                                    <TextBlock Text="{localization:Loc MatchGameplay_WordSelectionTitle}"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               Foreground="#462A1A"
                                               Margin="0,0,0,12"/>

                                    <StackPanel Visibility="{Binding CanSelectWord, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Text="{localization:Loc MatchGameplay_SelectWordLabel}"
                                                   FontSize="16"
                                                   Foreground="#462A1A"
                                                   Margin="0,0,0,8"/>

                                        <ComboBox ItemsSource="{Binding SelectableWords}"
                                                  SelectedItem="{Binding SelectedWord, Mode=TwoWay}"
                                                  DisplayMemberPath="WordText"
                                                  Height="45"
                                                  Style="{StaticResource RetroComboBoxStyle}"
                                                  Margin="0,0,0,12"/>

                                        <TextBlock Text="{Binding SelectedWordDescription}"
                                                   FontSize="15"
                                                   Foreground="#7A5A3A"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,16"/>

                                        <Button Content="{localization:Loc MatchGameplay_SelectWordButton}"
                                                Command="{Binding SelectWordCommand}"
                                                Width="240"
                                                Height="58"
                                                HorizontalAlignment="Left"
                                                Style="{StaticResource BotonRetroStyle}"/>
                                    </StackPanel>

                                    <TextBlock Text="{localization:Loc MatchGameplay_WaitingForHostWord}"
                                               FontSize="17"
                                               Foreground="#7A5A3A"
                                               TextWrapping="Wrap"
                                               Visibility="{Binding IsWaitingForHostSelection, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource GameplayCardStyle}"
                                    Visibility="{Binding IsInProgress, Converter={StaticResource BooleanToVisibilityConverter}}">

                                <StackPanel>
                                    <TextBlock Text="{localization:Loc MatchGameplay_InProgressTitle}"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               Foreground="#462A1A"
                                               Margin="0,0,0,12"/>

                                    <TextBlock Text="{localization:Loc MatchGameplay_InProgressMessage}"
                                               FontSize="17"
                                               Foreground="#7A5A3A"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="250"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Style="{StaticResource GameplayCardStyle}">

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Text="{localization:Loc MatchGameplay_VotesTitle}"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               Foreground="#462A1A"
                                               Margin="0,0,0,12"/>

                                    <Grid Grid.Row="1">
                                        <DataGrid ItemsSource="{Binding Votes}"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  IsReadOnly="True"
                                                  HeadersVisibility="Column"
                                                  GridLinesVisibility="Horizontal"
                                                  Background="#FFFDF8"
                                                  BorderBrush="#B58B5C"
                                                  BorderThickness="2"
                                                  RowBackground="#FFFDF8"
                                                  AlternatingRowBackground="#F7EBDD"
                                                  HorizontalGridLinesBrush="#D8C2A8"
                                                  VerticalGridLinesBrush="#D8C2A8"
                                                  Foreground="#462A1A"
                                                  FontSize="14">

                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="{localization:Loc MatchGameplay_PlayerColumn}"
                                                                    Binding="{Binding PlayerId}"
                                                                    Width="100"/>

                                                <DataGridTextColumn Header="{localization:Loc MatchGameplay_CategoryColumn}"
                                                                    Binding="{Binding CategoryName}"
                                                                    Width="*"/>
                                            </DataGrid.Columns>
                                        </DataGrid>

                                        <TextBlock Text="{localization:Loc MatchGameplay_NoVotes}"
                                                   Foreground="#7A5A3A"
                                                   FontSize="17"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding HasNoVotes, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    </Grid>
                                </Grid>
                            </Border>

                            <userControls:MatchChatView Grid.Row="1"
                                                        DataContext="{Binding Chat}"
                                                        Margin="0,4,0,0"/>
                        </Grid>
                    </Grid>

                    <Grid Grid.Row="3"
                          Margin="0,14,0,0">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="{localization:Loc Match_LeaveLobbyButton}"
                                Command="{Binding LeaveCommand}"
                                Width="220"
                                Height="60"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Style="{StaticResource BotonRetroStyle}"/>

                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Margin="20,0">

                            <TextBlock Text="{Binding ErrorMessage}"
                                       Foreground="Red"
                                       TextWrapping="Wrap"
                                       FontSize="15"
                                       Margin="0,0,0,6"/>

                            <TextBlock Text="{Binding SuccessMessage}"
                                       Foreground="Green"
                                       TextWrapping="Wrap"
                                       FontSize="15"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>