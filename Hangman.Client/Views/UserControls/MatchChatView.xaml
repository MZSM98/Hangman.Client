<UserControl x:Class="Hangman.Client.Views.UserControls.MatchChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:localization="clr-namespace:Hangman.Client.Localization"
             Background="Transparent"
             MinHeight="160">

    <Border Background="#F7E7CF"
            BorderBrush="#B58B5C"
            BorderThickness="2"
            CornerRadius="8"
            Padding="10">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="{localization:Loc MatchChat_Title}"
                       FontSize="17"
                       Foreground="#462A1A"
                       Margin="0,0,0,8"/>

            <ListBox x:Name="MessagesListBox"
                     Grid.Row="1"
                     ItemsSource="{Binding Messages}"
                     Background="#FFFDF8"
                     BorderBrush="#B58B5C"
                     BorderThickness="2"
                     MinHeight="120"
                     MaxHeight="190"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     FontFamily="{StaticResource FuentePixel}">

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="4,3">
                            <TextBlock FontSize="12"
                                       Foreground="#7A5A3A"
                                       TextWrapping="Wrap">
                                <Run Text="{Binding SenderFullName}"/>
                                <Run Text=": "/>
                            </TextBlock>

                            <TextBlock Text="{Binding Message}"
                                       FontSize="13"
                                       Foreground="#462A1A"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Grid Grid.Row="2"
                  Margin="0,8,0,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="MessageTextBox"
                         Grid.Column="0"
                         Text="{Binding MessageText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Height="38"
                         FontSize="13"
                         MaxLength="250"
                         AcceptsReturn="False"
                         VerticalContentAlignment="Center"
                         Margin="0,0,8,0"
                         KeyDown="OnMessageTextBoxKeyDown"/>

                <Button Grid.Column="1"
                        Content="{localization:Loc MatchChat_SendButton}"
                        Command="{Binding SendMessageCommand}"
                        Width="100"
                        Height="42"
                        FontSize="13"
                        Style="{StaticResource BotonRetroStyle}"/>
            </Grid>

            <TextBlock Grid.Row="3"
                       Text="{Binding ErrorMessage}"
                       Foreground="Red"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Margin="0,6,0,0"/>
        </Grid>
    </Border>
</UserControl>