<UserControl x:Class="Hangman.Client.Views.UserControls.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">


    <Grid Background="#2A1B14">
        <Border Background="#FAF3E6" Margin="10">

            <Grid Margin="50">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="GESTIÓN DE PERFIL" 
                           FontFamily="{StaticResource FuentePixel}" FontSize="45" 
                           Foreground="#462A1A" Margin="0,0,0,10"/>

                <Border Grid.Row="1" BorderBrush="#D09D6C" BorderThickness="0,0,0,2" Margin="0,0,0,50"/>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,80,0" VerticalAlignment="Top">

                        <Border Width="240" Height="240" CornerRadius="120" 
                                BorderBrush="#D6A57A" BorderThickness="8" Background="White" 
                                ClipToBounds="True" Margin="0,0,0,20">
                            <Grid>
                                <Ellipse Width="75" Height="75" Fill="#D6A57A" VerticalAlignment="Top" Margin="0,40,0,0"/>
                                <Ellipse Width="180" Height="140" Fill="#D6A57A" VerticalAlignment="Bottom" Margin="0,0,0,-50"/>
                            </Grid>
                        </Border>

                        <TextBlock Text="Avatar de Jugador" FontFamily="Segoe UI" FontSize="18" 
                                   Foreground="#462A1A" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <Grid Grid.Column="1" VerticalAlignment="Top">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,25">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="2*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Nombre:" FontFamily="Segoe UI" FontSize="18" Foreground="#2A1B14" Margin="0,0,0,5"/>
                                <TextBox Text="" Background="White" BorderBrush="#2A1B14" BorderThickness="1" Padding="10,8" FontSize="18" Height="40"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Teléfono:" FontFamily="Segoe UI" FontSize="18" Foreground="#2A1B14" Margin="0,0,0,5"/>
                                <TextBox Text="" Background="White" BorderBrush="#2A1B14" BorderThickness="1" Padding="10,8" FontSize="18" Height="40"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Row="1" Margin="0,0,0,25">
                            <TextBlock Text="Correo Electrónico:" FontFamily="Segoe UI" FontSize="18" Foreground="#2A1B14" Margin="0,0,0,5"/>
                            <TextBox Text="juan.perez@dominio.com" Background="#EAEAEA" BorderBrush="#2A1B14" BorderThickness="1" Padding="10,8" FontSize="18" Height="40" IsReadOnly="True" Foreground="#555555"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Margin="0,0,0,40">
                            <TextBlock Text="Fecha de Nacimiento:" FontFamily="Segoe UI" FontSize="18" Foreground="#2A1B14" Margin="0,0,0,5"/>
                            <DatePicker Text="" Background="White" BorderBrush="#2A1B14" BorderThickness="1" FontSize="18" Height="40"/>
                        </StackPanel>

                        <Button Grid.Row="3" Content="CANCELAR" 
                                Width="220" Height="60" HorizontalAlignment="Right"
                                FontFamily="{StaticResource FuentePixel}"
                                Style="{StaticResource BotonRetroStyle}" Margin="0,0,4,20"/>
                        <Button Grid.Row="3" Content="GUARDAR" 
                            Width="220" Height="60" HorizontalAlignment="Left"
                            FontFamily="{StaticResource FuentePixel}"
                            Style="{StaticResource BotonRetroStyle}" Margin="266,0,0,20"/>

                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>