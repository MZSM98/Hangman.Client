<UserControl x:Class="Hangman.Client.Views.UserControls.ResetPasswordView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:localization="clr-namespace:Hangman.Client.Localization"
             mc:Ignorable="d"
             FontFamily="{StaticResource FuentePixel}">
    
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Padding="20">

            <Border MaxWidth="900"
                MinWidth="720"
                Background="#FDF8F5"
                CornerRadius="10"
                BorderBrush="#B58B5C"
                BorderThickness="3"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

                <Grid Margin="60,45,60,45">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                           Text="{localization:Loc ResetPassword_Title}"
                           FontSize="36"
                           FontWeight="Bold"
                           Foreground="#8C5A35"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,0,0,20"/>

                    <TextBlock Grid.Row="1"
                           Text="{localization:Loc ResetPassword_Description}"
                           FontSize="20"
                           Foreground="#555555"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,0,0,30"/>

                    <StackPanel Grid.Row="2" Margin="0,0,0,20">
                        <TextBlock Text="{localization:Loc ResetPassword_EmailLabel}"
                               FontSize="24"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Margin="0,0,0,6"/>

                        <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Margin="0,0,0,20">
                        <TextBlock Text="{localization:Loc ResetPassword_CodeLabel}"
                               FontSize="24"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Margin="0,0,0,6"/>

                        <TextBox x:Name="RecoveryCodeTextBox"
                             Text="{Binding Code, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="{localization:Loc ResetPassword_CodeTooltip}"
                             MaxLength="6"
                             InputScope="Number"
                             FontSize="22"
                             HorizontalContentAlignment="Center"
                             PreviewTextInput="RecoveryCodeTextBox_PreviewTextInput"
                             DataObject.Pasting="RecoveryCodeTextBox_Pasting"/>
                    </StackPanel>

                    <Grid Grid.Row="4" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{localization:Loc ResetPassword_NewPasswordLabel}"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,6"/>

                            <PasswordBox x:Name="NewPasswordBox"
                                     PasswordChanged="NewPasswordBox_PasswordChanged"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{localization:Loc ResetPassword_ConfirmPasswordLabel}"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,6"/>

                            <PasswordBox x:Name="ConfirmPasswordBox"
                                     PasswordChanged="ConfirmPasswordBox_PasswordChanged"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Row="5" Margin="0,0,0,18">
                        <TextBlock Text="{Binding ErrorMessage}"
                               FontSize="17"
                               Foreground="#9B1C1C"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>

                        <TextBlock Text="{Binding SuccessMessage}"
                               FontSize="17"
                               Foreground="#1F6B2A"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"/>
                    </StackPanel>

                    <Button Grid.Row="6"
                        Content="{localization:Loc ResetPassword_Button}"
                        Height="68"
                        MinWidth="300"
                        MaxWidth="480"
                        HorizontalAlignment="Center"
                        Command="{Binding ResetPasswordCommand}"
                        Style="{StaticResource BotonMaderaStyle}"
                        Padding="20,14,20,8"
                        FontSize="22"
                        Margin="0,0,0,24"/>

                    <TextBlock Grid.Row="7"
                           Text="{localization:Loc ResetPassword_BackToLogin}"
                           FontSize="20"
                           Foreground="#8C5A35"
                           FontWeight="SemiBold"
                           Cursor="Hand"
                           TextDecorations="Underline"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap">

                        <TextBlock.InputBindings>
                            <MouseBinding Gesture="LeftClick"
                                      Command="{Binding OpenLoginCommand}"/>
                        </TextBlock.InputBindings>
                    </TextBlock>
                </Grid>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>
