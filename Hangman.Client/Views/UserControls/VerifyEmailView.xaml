<UserControl x:Class="Hangman.Client.Views.UserControls.VerifyEmailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:localization="clr-namespace:Hangman.Client.Localization"
             mc:Ignorable="d"
             FontFamily="{StaticResource FuentePixel}">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Padding="20">

            <Border MaxWidth="850"
                MinWidth="700"
                Background="#FDF8F5"
                CornerRadius="10"
                BorderBrush="#B58B5C"
                BorderThickness="3"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

                <Grid Margin="60,45,60,45">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                           Text="{localization:Loc VerifyEmail_Title}"
                           FontSize="36"
                           FontWeight="Bold"
                           Foreground="#8C5A35"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,0,0,20"/>

                    <TextBlock Grid.Row="1"
                           Text="{localization:Loc VerifyEmail_Description}"
                           FontSize="20"
                           Foreground="#555555"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,0,0,30"/>

                    <StackPanel Grid.Row="2" Margin="0,0,0,22">
                        <TextBlock Text="{localization:Loc VerifyEmail_EmailLabel}"
                               FontSize="24"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Margin="0,0,0,6"/>

                        <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Margin="0,0,0,22">
                        <TextBlock Text="{localization:Loc VerifyEmail_CodeLabel}"
                               FontSize="24"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Margin="0,0,0,6"/>

                        <TextBox x:Name="VerificationCodeTextBox"
                             Text="{Binding Code, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="{localization:Loc VerifyEmail_CodeTooltip}"
                             MaxLength="6"
                             InputScope="Number"
                             FontSize="22"
                             HorizontalContentAlignment="Center"
                             PreviewTextInput="VerificationCodeTextBox_PreviewTextInput"
                             DataObject.Pasting="VerificationCodeTextBox_Pasting"/>
                    </StackPanel>

                    <StackPanel Grid.Row="4" Margin="0,0,0,20">
                        <TextBlock Text="{Binding ErrorMessage}"
                               FontSize="17"
                               Foreground="#9B1C1C"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>

                        <TextBlock Text="{Binding SuccessMessage}"
                               FontSize="17"
                               Foreground="#1F6B2A"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"/>
                    </StackPanel>

                    <Grid Grid.Row="5" Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                            Content="{localization:Loc VerifyEmail_Button}"
                            Height="68"
                            Command="{Binding VerifyEmailCommand}"
                            Style="{StaticResource BotonMaderaStyle}"
                            Padding="20,14,20,8"
                            FontSize="22"/>

                        <Button Grid.Column="2"
                            Content="{localization:Loc VerifyEmail_ResendCodeButton}"
                            Height="68"
                            Command="{Binding ResendCodeCommand}"
                            Style="{StaticResource BotonMaderaStyle}"
                            Padding="20,14,20,8"
                            FontSize="20"/>
                    </Grid>

                    <TextBlock Grid.Row="6"
                           Text="{localization:Loc VerifyEmail_BackToLogin}"
                           FontSize="20"
                           Foreground="#8C5A35"
                           FontWeight="SemiBold"
                           Cursor="Hand"
                           TextDecorations="Underline"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap">

                        <TextBlock.InputBindings>
                            <MouseBinding Gesture="LeftClick"
                                      Command="{Binding OpenLoginCommand}"/>
                        </TextBlock.InputBindings>
                    </TextBlock>
                </Grid>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>
