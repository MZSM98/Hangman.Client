<UserControl x:Class="Hangman.Client.Views.UserControls.MatchGuessView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:userControls="clr-namespace:Hangman.Client.Views.UserControls"
             Background="Transparent"
             MinWidth="800"
             MinHeight="500">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style x:Key="GuessCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#F7E7CF"/>
            <Setter Property="BorderBrush" Value="#B58B5C"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="LetterKeyButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Foreground" Value="#462A1A"/>
            <Setter Property="Background" Value="#E5B16E"/>
            <Setter Property="BorderBrush" Value="#462A1A"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0,4,0,0"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border Background="#462A1A"
                                    Margin="3,3,-3,-3"
                                    CornerRadius="4"/>

                            <Border x:Name="KeyFront"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4">

                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="KeyFront"
                                        Property="Background"
                                        Value="#F2C88B"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="KeyFront"
                                        Property="Margin"
                                        Value="2,2,-2,-2"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Cursor" Value="Arrow"/>
                                <Setter Property="Foreground" Value="#4C3A2C"/>
                                <Setter TargetName="KeyFront"
                                        Property="Background"
                                        Value="#8B7A66"/>
                                <Setter TargetName="KeyFront"
                                        Property="BorderBrush"
                                        Value="#5E4A38"/>
                            </Trigger>

                            <DataTrigger Binding="{Binding IsCorrect}" Value="True">
                                <Setter Property="Foreground" Value="#2F4A23"/>
                                <Setter TargetName="KeyFront"
                                        Property="Background"
                                        Value="#A9B77A"/>
                                <Setter TargetName="KeyFront"
                                        Property="BorderBrush"
                                        Value="#596B35"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GuessActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#462A1A"/>
            <Setter Property="Background" Value="#F39B2E"/>
            <Setter Property="BorderBrush" Value="#462A1A"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="MinHeight" Value="44"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Margin="0,0,6,6">
                            <Border Background="#462A1A"
                                    Margin="6,6,0,0"
                                    CornerRadius="3"/>

                            <Border x:Name="ButtonFront"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="3"
                                    Margin="0,0,6,6">

                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonFront"
                                        Property="Background"
                                        Value="#FFB04A"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonFront"
                                        Property="Margin"
                                        Value="3,3,3,3"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#6D5A48"/>
                                <Setter TargetName="ButtonFront"
                                        Property="Background"
                                        Value="#9B8061"/>
                                <Setter TargetName="ButtonFront"
                                        Property="BorderBrush"
                                        Value="#5E4A38"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="Transparent">
        <Border Width="1500"
                Height="820"
                Background="#FAF3E6"
                BorderBrush="#B58B5C"
                BorderThickness="4"
                CornerRadius="10"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

            <Border BorderBrush="#462A1A"
                    BorderThickness="2"
                    Margin="15">

                <Grid Margin="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="76"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="¡ADIVINA LA PALABRA!"
                               FontSize="40"
                               Foreground="#462A1A"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#8C5A35"
                                              BlurRadius="0"
                                              ShadowDepth="4"
                                              Direction="315"
                                              Opacity="0.7"/>
                        </TextBlock.Effect>
                    </TextBlock>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.05*"/>
                            <ColumnDefinition Width="0.95*"/>
                            <ColumnDefinition Width="360"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0"
                              Margin="0,0,18,0">

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Style="{StaticResource GuessCardStyle}">

                                <StackPanel>
                                    <TextBlock FontSize="15"
                                               Foreground="#462A1A"
                                               TextWrapping="Wrap">
                                        <Run Text="HOST: "/>
                                        <Run Text="{Binding GameState.HostFullName, Mode=OneWay}"/>
                                        <Run Text="  |  GUEST: "/>
                                        <Run Text="{Binding GameState.GuestFullName, Mode=OneWay}"/>
                                    </TextBlock>

                                    <TextBlock FontSize="16"
                                               Foreground="#7A5A3A"
                                               TextWrapping="Wrap"
                                               Margin="0,10,0,0">
                                        <Run Text="PISTA: "/>
                                        <Run Text="{Binding HintText, Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1"
                                    Style="{StaticResource GuessCardStyle}"
                                    Width="250"
                                    HorizontalAlignment="Left"
                                    Visibility="{Binding IsTimerVisible, Converter={StaticResource BooleanToVisibilityConverter}}">

                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center">

                                    <TextBlock Text="TIEMPO: "
                                               FontSize="19"
                                               Foreground="#462A1A"/>

                                    <TextBlock Text="{Binding RemainingSeconds, Mode=OneWay}"
                                               FontSize="22"
                                               Foreground="#9E3222"/>

                                    <TextBlock Text="s"
                                               FontSize="19"
                                               Foreground="#462A1A"
                                               Margin="4,0,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="2"
                                    Style="{StaticResource GuessCardStyle}"
                                    MinHeight="120"
                                    VerticalAlignment="Stretch">

                                <Grid Margin="8"
                                      ClipToBounds="True">

                                    <ItemsControl ItemsSource="{Binding LetterSlots}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center">

                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"
                                                            HorizontalAlignment="Center"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>

                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="{Binding DataContext.SlotLayout.Width, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        Height="{Binding DataContext.SlotLayout.Height, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        Margin="1"
                                                        BorderBrush="#462A1A"
                                                        BorderThickness="0,0,0,3"
                                                        Background="Transparent">

                                                    <TextBlock Text="{Binding Letter, Mode=OneWay}"
                                                               FontSize="{Binding DataContext.SlotLayout.FontSize, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                               Foreground="#462A1A"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               TextAlignment="Center"
                                                               Padding="0"
                                                               Margin="0"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>

                            <Border Grid.Row="3"
                                    Style="{StaticResource GuessCardStyle}"
                                    Visibility="{Binding IsGuestControlsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">

                                <StackPanel>
                                    <Button Content="ADIVINAR PALABRA"
                                            Command="{Binding OpenWordGuessPanelCommand}"
                                            Height="54"
                                            FontSize="16"
                                            Style="{StaticResource GuessActionButtonStyle}"
                                            Visibility="{Binding IsWordGuessInitialButtonVisible, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                    <StackPanel Visibility="{Binding IsWordGuessPanelVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Text="Advertencia: si escribes la palabra completa y te equivocas, perderás la partida automáticamente."
                                                   FontSize="13"
                                                   Foreground="#9E3222"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,8"/>

                                        <Grid Height="54"
                                              VerticalAlignment="Center">

                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBox Grid.Column="0"
                                                     Text="{Binding GuessWordText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     FontSize="15"
                                                     Height="40"
                                                     Margin="0,0,10,0"
                                                     VerticalAlignment="Center"
                                                     VerticalContentAlignment="Center"/>

                                            <Button Grid.Column="1"
                                                    Content="CONFIRMAR"
                                                    Command="{Binding GuessWordCommand}"
                                                    Width="122"
                                                    Height="48"
                                                    Margin="0,0,10,0"
                                                    FontSize="13"
                                                    VerticalAlignment="Center"
                                                    Style="{StaticResource GuessActionButtonStyle}"/>

                                            <Button Grid.Column="2"
                                                    Content="CANCELAR"
                                                    Command="{Binding CancelWordGuessCommand}"
                                                    Width="112"
                                                    Height="48"
                                                    FontSize="13"
                                                    VerticalAlignment="Center"
                                                    Style="{StaticResource GuessActionButtonStyle}"/>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="340"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Style="{StaticResource GuessCardStyle}">

                                <Grid>
                                    <Canvas Width="360"
                                            Height="270"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">

                                        <Line X1="70" Y1="250" X2="310" Y2="250"
                                              Stroke="#6B3E22"
                                              StrokeThickness="8"/>

                                        <Line X1="275" Y1="250" X2="275" Y2="25"
                                              Stroke="#6B3E22"
                                              StrokeThickness="8"/>

                                        <Line X1="110" Y1="25" X2="280" Y2="25"
                                              Stroke="#6B3E22"
                                              StrokeThickness="8"/>

                                        <Line X1="110" Y1="25" X2="110" Y2="62"
                                              Stroke="#462A1A"
                                              StrokeThickness="4"/>

                                        <Ellipse Width="52"
                                                 Height="52"
                                                 Canvas.Left="84"
                                                 Canvas.Top="62"
                                                 Stroke="#462A1A"
                                                 StrokeThickness="4"
                                                 Visibility="{Binding ShowHead, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                        <Line X1="110" Y1="114" X2="110" Y2="178"
                                              Stroke="#462A1A"
                                              StrokeThickness="4"
                                              Visibility="{Binding ShowTorso, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                        <Line X1="110" Y1="135" X2="72" Y2="168"
                                              Stroke="#462A1A"
                                              StrokeThickness="4"
                                              Visibility="{Binding ShowLeftArm, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                        <Line X1="110" Y1="135" X2="148" Y2="168"
                                              Stroke="#462A1A"
                                              StrokeThickness="4"
                                              Visibility="{Binding ShowRightArm, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                        <Line X1="110" Y1="178" X2="76" Y2="228"
                                              Stroke="#462A1A"
                                              StrokeThickness="4"
                                              Visibility="{Binding ShowLeftLeg, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                        <Line X1="110" Y1="178" X2="144" Y2="228"
                                              Stroke="#462A1A"
                                              StrokeThickness="4"
                                              Visibility="{Binding ShowRightLeg, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    </Canvas>

                                    <Border Background="#E5C39C"
                                            BorderBrush="#462A1A"
                                            BorderThickness="3"
                                            CornerRadius="6"
                                            Padding="10,7"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Bottom"
                                            Margin="0,0,6,6">

                                        <TextBlock FontSize="18"
                                                   Foreground="#462A1A">
                                            <Run Text="FALLOS: "/>
                                            <Run Text="{Binding FailedAttempts, Mode=OneWay}"/>
                                            <Run Text=" / "/>
                                            <Run Text="{Binding MaxAttempts, Mode=OneWay}"/>
                                        </TextBlock>
                                    </Border>
                                </Grid>
                            </Border>

                            <Border Grid.Row="1"
                                    Style="{StaticResource GuessCardStyle}"
                                    Padding="10"
                                    Margin="0"
                                    Visibility="{Binding IsGuestControlsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">

                                <ItemsControl ItemsSource="{Binding LetterKeys}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="10"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>

                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding Letter, Mode=OneWay}"
                                                    Command="{Binding GuessCommand}"
                                                    IsEnabled="{Binding IsEnabled, Mode=OneWay}"
                                                    Style="{StaticResource LetterKeyButtonStyle}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>

                            <Border Grid.Row="1"
                                    Style="{StaticResource GuessCardStyle}"
                                    Padding="14"
                                    Margin="0"
                                    Visibility="{Binding IsHostReadOnlyVisible, Converter={StaticResource BooleanToVisibilityConverter}}">

                                <StackPanel VerticalAlignment="Center"
                                            Margin="0,8,0,8">

                                    <TextBlock Text="VISTA DEL HOST"
                                               FontSize="20"
                                               LineHeight="28"
                                               LineStackingStrategy="BlockLineHeight"
                                               Foreground="#462A1A"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,14"/>

                                    <TextBlock Text="Palabra seleccionada"
                                               FontSize="14"
                                               LineHeight="22"
                                               LineStackingStrategy="BlockLineHeight"
                                               Foreground="#7A5A3A"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,8"/>

                                    <TextBlock FontSize="16"
                                               LineHeight="24"
                                               LineStackingStrategy="BlockLineHeight"
                                               Foreground="#462A1A"
                                               TextAlignment="Center"
                                               Margin="0,0,0,8">
                                        <Run Text="Fallos del invitado: "/>
                                        <Run Text="{Binding FailedAttempts, Mode=OneWay}"/>
                                        <Run Text=" / "/>
                                        <Run Text="{Binding MaxAttempts, Mode=OneWay}"/>
                                    </TextBlock>

                                    <TextBlock FontSize="16"
                                               LineHeight="24"
                                               LineStackingStrategy="BlockLineHeight"
                                               Foreground="#462A1A"
                                               TextAlignment="Center">
                                        <Run Text="Intentos restantes: "/>
                                        <Run Text="{Binding RemainingAttempts, Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <userControls:MatchChatView Grid.Column="2"
                                                    DataContext="{Binding Chat}"
                                                    Margin="18,0,0,0"
                                                    VerticalAlignment="Stretch"/>
                    </Grid>

                    <Grid Grid.Row="2"
                          Margin="0,14,0,0">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="RENDIRSE"
                                Command="{Binding SurrenderCommand}"
                                Width="200"
                                Height="62"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                FontSize="18"
                                Style="{StaticResource GuessActionButtonStyle}"/>

                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Margin="20,0">

                            <TextBlock Text="{Binding ErrorMessage, Mode=OneWay}"
                                       Foreground="Red"
                                       TextWrapping="Wrap"
                                       FontSize="14"
                                       Margin="0,0,0,6"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>