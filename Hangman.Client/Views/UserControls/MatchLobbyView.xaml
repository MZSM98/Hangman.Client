<UserControl x:Class="Hangman.Client.Views.UserControls.MatchLobbyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:localization="clr-namespace:Hangman.Client.Localization"
             Background="Transparent"
             MinWidth="800"
             MinHeight="500">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style x:Key="MatchLobbyDisabledButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource BotonRetroStyle}">
            
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.55"/>
                    <Setter Property="Background" Value="#5A4632"/>
                    <Setter Property="Foreground" Value="#D8C2A8"/>
                    <Setter Property="BorderBrush" Value="#2E2118"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="Transparent">
        <Border Width="1250"
                Height="760"
                Background="#FAF3E6"
                BorderBrush="#B58B5C"
                BorderThickness="4"
                CornerRadius="10"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

            <Border BorderBrush="#462A1A"
                    BorderThickness="2"
                    Margin="15,15,15,25">

                <Grid Margin="28">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="{localization:Loc Match_Title}"
                               FontSize="34"
                               Foreground="#462A1A"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#8C5A35"
                                              BlurRadius="0"
                                              ShadowDepth="4"
                                              Direction="315"
                                              Opacity="0.7"/>
                        </TextBlock.Effect>
                    </TextBlock>

                    <Grid Grid.Row="1"
                          Width="720"
                          HorizontalAlignment="Center"
                          Margin="0,0,0,18">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="{localization:Loc Match_CreateLobbyButton}"
                                Command="{Binding CreateLobbyCommand}"
                                Width="220"
                                Height="60"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Style="{StaticResource MatchLobbyDisabledButtonStyle}"/>

                        <Button Grid.Column="1"
                                Content="{localization:Loc Match_RefreshLobbiesButton}"
                                Command="{Binding RefreshLobbiesCommand}"
                                Width="220"
                                Height="60"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Style="{StaticResource MatchLobbyDisabledButtonStyle}"/>

                        <Button Grid.Column="2"
                                Content="{localization:Loc Match_BackButton}"
                                Command="{Binding BackCommand}"
                                Width="220"
                                Height="60"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Style="{StaticResource MatchLobbyDisabledButtonStyle}"/>
                    </Grid>

                    <Border Grid.Row="2"
                            Background="#F7E7CF"
                            BorderBrush="#B58B5C"
                            BorderThickness="2"
                            CornerRadius="6"
                            Padding="14"
                            Margin="0,0,0,18">

                        <StackPanel>
                            <TextBlock Text="{localization:Loc Match_CurrentLobbyTitle}"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="#462A1A"
                                       Margin="0,0,0,8"/>

                            <TextBlock Foreground="#462A1A"
                                       FontSize="16"
                                       Visibility="{Binding HasCurrentLobby, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Run Text="{localization:Loc Match_HostLabel}"/>
                                <Run Text=": "/>
                                <Run Text="{Binding CurrentLobby.HostFullName}"/>
                                <Run Text="   |   "/>
                                <Run Text="{localization:Loc Match_StatusLabel}"/>
                                <Run Text=": "/>
                                <Run Text="{Binding CurrentLobby.MatchStatus}"/>
                            </TextBlock>

                            <TextBlock Foreground="#462A1A"
                                       FontSize="16"
                                       Margin="0,6,0,0"
                                       Visibility="{Binding HasCurrentLobby, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Run Text="{localization:Loc Match_GuestLabel}"/>
                                <Run Text=": "/>
                                <Run Text="{Binding CurrentLobby.GuestFullName}"/>
                            </TextBlock>

                            <TextBlock Text="{localization:Loc Match_NoCurrentLobby}"
                                       Foreground="#7A5A3A"
                                       FontSize="15"
                                       Visibility="{Binding HasNoCurrentLobby, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="3"
                          Visibility="{Binding HasNoCurrentLobby, Converter={StaticResource BooleanToVisibilityConverter}}">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="{localization:Loc Match_AvailableLobbiesTitle}"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#462A1A"
                                   Margin="0,0,0,10"/>

                        <Border Grid.Row="1"
                                Background="#FFFDF8"
                                BorderBrush="#B58B5C"
                                BorderThickness="2"
                                CornerRadius="6">

                            <Grid>
                                <DataGrid ItemsSource="{Binding AvailableLobbies}"
                                          SelectedItem="{Binding SelectedLobby, Mode=TwoWay}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          RowBackground="#FFFDF8"
                                          AlternatingRowBackground="#F7EBDD"
                                          HorizontalGridLinesBrush="#D8C2A8"
                                          VerticalGridLinesBrush="#D8C2A8"
                                          Foreground="#462A1A"
                                          FontSize="15"
                                          Margin="6">

                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="{localization:Loc Match_HostLabel}"
                                                            Binding="{Binding HostFullName}"
                                                            Width="*"/>

                                        <DataGridTextColumn Header="{localization:Loc Match_EmailLabel}"
                                                            Binding="{Binding HostEmail}"
                                                            Width="*"/>

                                        <DataGridTextColumn Header="{localization:Loc Match_CreatedAtLabel}"
                                                            Binding="{Binding CreatedAt, StringFormat={}{0:dd/MM/yyyy HH:mm}}"
                                                            Width="220"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <TextBlock Text="{localization:Loc Match_NoAvailableLobbies}"
                                           Foreground="#7A5A3A"
                                           FontSize="18"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding HasNoAvailableLobbies, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="4"
                          Margin="0,18,0,0">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="{localization:Loc Match_LeaveLobbyButton}"
                                Command="{Binding LeaveLobbyCommand}"
                                Width="220"
                                Height="60"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Style="{StaticResource BotonRetroStyle}"
                                Visibility="{Binding HasCurrentLobby, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Margin="20,0">

                            <TextBlock Text="{Binding ErrorMessage}"
                                       Foreground="Red"
                                       TextWrapping="Wrap"
                                       FontSize="15"
                                       Margin="0,0,0,6"/>

                            <TextBlock Text="{Binding SuccessMessage}"
                                       Foreground="Green"
                                       TextWrapping="Wrap"
                                       FontSize="15"/>
                        </StackPanel>

                        <Button Grid.Column="2"
                                Content="{localization:Loc Match_JoinLobbyButton}"
                                Command="{Binding JoinLobbyCommand}"
                                Width="220"
                                Height="60"
                                VerticalAlignment="Center"
                                Style="{StaticResource BotonRetroStyle}"
                                Visibility="{Binding HasNoCurrentLobby, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </Grid>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>