<Window x:Class="Hangman.Client.Views.Windows.RequestPasswordResetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:localization="clr-namespace:Hangman.Client.Localization"
        mc:Ignorable="d"
        Title="{localization:Loc RequestPasswordReset_WindowTitle}"
        Height="1080"
        Width="1920"
        MinHeight="720"
        MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        FontFamily="{StaticResource FuentePixel}">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/Assets/HangmanBackground.jpg" Stretch="UniformToFill"/>
        </Grid.Background>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="20">

            <Border MaxWidth="850"
                    MinWidth="700"
                    Background="#FDF8F5"
                    CornerRadius="10"
                    BorderBrush="#B58B5C"
                    BorderThickness="3"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">

                <Grid Margin="60,45,60,45">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="{localization:Loc RequestPasswordReset_Title}"
                               FontSize="36"
                               FontWeight="Bold"
                               Foreground="#8C5A35"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="0,0,0,20"/>

                    <TextBlock Grid.Row="1"
                               Text="{localization:Loc RequestPasswordReset_Description}"
                               FontSize="20"
                               Foreground="#555555"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="0,0,0,30"/>

                    <StackPanel Grid.Row="2" Margin="0,0,0,22">
                        <TextBlock Text="{localization:Loc RequestPasswordReset_EmailLabel}"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,6"/>

                        <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Margin="0,0,0,20">
                        <TextBlock Text="{Binding ErrorMessage}"
                                   FontSize="17"
                                   Foreground="#9B1C1C"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>

                        <TextBlock Text="{Binding SuccessMessage}"
                                   FontSize="17"
                                   Foreground="#1F6B2A"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <Button Grid.Row="4"
                            Content="{localization:Loc RequestPasswordReset_Button}"
                            Height="68"
                            MinWidth="280"
                            MaxWidth="430"
                            HorizontalAlignment="Center"
                            Command="{Binding RequestPasswordResetCommand}"
                            Style="{StaticResource BotonMaderaStyle}"
                            Padding="20,14,20,8"
                            FontSize="22"
                            Margin="0,0,0,24"/>

                    <TextBlock Grid.Row="5"
                               Text="{localization:Loc RequestPasswordReset_BackToLogin}"
                               FontSize="20"
                               Foreground="#8C5A35"
                               FontWeight="SemiBold"
                               Cursor="Hand"
                               TextDecorations="Underline"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap">

                        <TextBlock.InputBindings>
                            <MouseBinding Gesture="LeftClick"
                                          Command="{Binding OpenLoginCommand}"/>
                        </TextBlock.InputBindings>
                    </TextBlock>
                </Grid>
            </Border>
        </ScrollViewer>
    </Grid>
</Window>