<Window x:Class="Hangman.Client.Views.Windows.LoginMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:localization="clr-namespace:Hangman.Client.Localization"
        xmlns:viewModels="clr-namespace:Hangman.Client.ViewModels"
        xmlns:userControls="clr-namespace:Hangman.Client.Views.UserControls"
        mc:Ignorable="d"
        Height="720"
        Width="1280"
        MinHeight="540"
        MinWidth="960"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        FontFamily="{StaticResource FuentePixel}"
        Title="{localization:Loc Login_WindowTitle}">

    <Window.Resources>
        <DataTemplate DataType="{x:Type viewModels:LoginViewModel}">
            <userControls:LoginView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:RegisterViewModel}">
            <userControls:RegisterView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:VerifyEmailViewModel}">
            <userControls:VerifyEmailView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:RequestPasswordResetViewModel}">
            <userControls:RequestPasswordResetView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:ResetPasswordViewModel}">
            <userControls:ResetPasswordView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/Assets/HangmanBackground.jpg"
                        Stretch="UniformToFill"/>
        </Grid.Background>

        <Viewbox Stretch="Uniform"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center">

            <Grid Width="1920"
                  Height="1080">

                <ContentControl Content="{Binding CurrentViewModel}"/>
            </Grid>
        </Viewbox>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,8,12,0">

            <Button Content="{localization:Loc Language_Spanish}"
                    Click="OnSetSpanish"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    Padding="4,2"
                    FontSize="13"
                    FontFamily="Segoe UI"
                    FontWeight="Medium"
                    Foreground="White"/>

            <TextBlock Text=" | "
                       Foreground="White"
                       FontSize="13"
                       FontFamily="Segoe UI"
                       VerticalAlignment="Center"/>

            <Button Content="{localization:Loc Language_English}"
                    Click="OnSetEnglish"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    Padding="4,2"
                    FontSize="13"
                    FontFamily="Segoe UI"
                    FontWeight="Medium"
                    Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>