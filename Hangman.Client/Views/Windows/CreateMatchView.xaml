<Window x:Class="Hangman.Client.Views.CreateMatchView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        mc:Ignorable="d" 
        Title="El Ahorcado - Configuración de Nueva Partida" d:DesignHeight="1080" d:DesignWidth="1920"
        WindowStartupLocation="CenterScreen" WindowState="Maximized"
        FontFamily="{StaticResource FuentePixel}">

    <Border Background="#E6F2E3D5">
        <Grid Margin="100" MaxWidth="1500" VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="CONFIGURACIÓN DE NUEVA PARTIDA" FontSize="60" FontWeight="Bold" Foreground="{StaticResource ColorTexto}" HorizontalAlignment="Center"/>
            <Border Grid.Row="1" Height="4" Background="{StaticResource ColorMaderaBorde}" Margin="0,30,0,60" HorizontalAlignment="Stretch" CornerRadius="2"/>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" BorderBrush="{StaticResource ColorMaderaBorde}" BorderThickness="4" CornerRadius="15" Padding="50" Background="#F8EAD9" VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="1. SELECCIONA CATEGORÍA" FontSize="36" FontWeight="Bold" Margin="0,0,0,30"/>
                        <RadioButton Content="Tecnología" FontSize="32" Margin="20,10"/>
                        <RadioButton Content="Animales" FontSize="32" Margin="20,10"/>
                        <RadioButton Content="Países" FontSize="32" Margin="20,10" IsChecked="True"/>

                        <TextBlock Text="2. IDIOMA DE PALABRA" FontSize="36" FontWeight="Bold" Margin="0,60,0,30"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="ESPAÑOL" Style="{StaticResource BotonRetroStyle}" Width="220" Height="75" FontSize="28" Margin="0,0,20,0"/>
                            <Button Content="ENGLISH" Style="{StaticResource BotonRetroStyle}" Width="220" Height="75" FontSize="28" Margin="20,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Width="4" Background="{StaticResource ColorMaderaBorde}" Margin="80,0" CornerRadius="2"/>

                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="⏳" FontSize="150" HorizontalAlignment="Center" Foreground="{StaticResource ColorMaderaBorde}" Margin="0,0,0,0"/>
                    <TextBlock Text="Una vez generada, deberás esperar a que un retador acepte tu partida." 
                               FontSize="36" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,60" Foreground="{StaticResource ColorTexto}"/>

                    <Button Content="GENERAR PARTIDA" Style="{StaticResource BotonRetroStyle}" Width="450" Height="100" FontSize="36" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>