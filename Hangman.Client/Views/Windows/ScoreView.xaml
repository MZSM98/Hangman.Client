<UserControl x:Class="Hangman.Client.Views.Windows.ScoreView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:localization="clr-namespace:Hangman.Client.Localization"
        mc:Ignorable="d"
        FontFamily="{StaticResource FuentePixel}">

    <Border Background="#E6F2E3D5">
        <Grid Margin="40" MaxWidth="1400" VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="{localization:Loc Score_Title}"
                       FontSize="55"
                       FontWeight="Bold"
                       Foreground="{StaticResource ColorTexto}"
                       HorizontalAlignment="Center"/>

            <Border Grid.Row="1"
                    Height="4"
                    Background="{StaticResource ColorMaderaBorde}"
                    Margin="0,20,0,40"
                    HorizontalAlignment="Stretch"
                    CornerRadius="2"/>

            <Grid Grid.Row="2" HorizontalAlignment="Center" Width="1200">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,30">
                    <TextBlock Text="{localization:Loc Score_ChallengerWins}"
                               FontSize="22"
                               FontWeight="Bold"
                               Margin="0,0,0,12"
                               HorizontalAlignment="Center"/>
                    <Border Background="#F2A65A"
                            BorderBrush="#D98A3C"
                            BorderThickness="3"
                            CornerRadius="8"
                            Padding="20,15"
                            HorizontalAlignment="Stretch">
                        <TextBlock FontSize="28" Foreground="#3D2314" HorizontalAlignment="Center">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0} Puntos ({1} Victorias)">
                                    <Binding Path="GuesserWinTotal"/>
                                    <Binding Path="GuesserWinCount"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,30">
                    <TextBlock Text="{localization:Loc Score_HostWins}"
                               FontSize="22"
                               FontWeight="Bold"
                               Margin="0,0,0,12"
                               HorizontalAlignment="Center"/>
                    <Border Background="#F9D479"
                            BorderBrush="#D7B152"
                            BorderThickness="3"
                            CornerRadius="8"
                            Padding="20,15"
                            HorizontalAlignment="Stretch">
                        <TextBlock FontSize="28" Foreground="#3D2314" HorizontalAlignment="Center">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0} Puntos ({1} Victorias)">
                                    <Binding Path="HostWinTotal"/>
                                    <Binding Path="HostWinCount"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.ColumnSpan="3" HorizontalAlignment="Center" Margin="0,0,0,10">
                    <TextBlock Text="{localization:Loc Score_Penalties}"
                               FontSize="22"
                               FontWeight="Bold"
                               Margin="0,0,0,12"
                               HorizontalAlignment="Center"/>
                    <Border Background="#F27474"
                            BorderBrush="#C94F4F"
                            BorderThickness="3"
                            CornerRadius="8"
                            Padding="20,15"
                            Width="500">
                        <TextBlock FontSize="28" Foreground="#FFFFFF" FontWeight="Bold" HorizontalAlignment="Center">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0} Puntos ({1} Abandonos)">
                                    <Binding Path="PenaltyTotal"/>
                                    <Binding Path="PenaltyCount"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </Border>
                </StackPanel>
            </Grid>

            <Border Grid.Row="3"
                    Height="4"
                    Background="{StaticResource ColorMaderaBorde}"
                    Margin="0,30,0,20"
                    HorizontalAlignment="Stretch"
                    CornerRadius="2"/>

            <TextBlock Grid.Row="4"
                       FontSize="60"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Foreground="{StaticResource ColorTexto}">
                <TextBlock.Text>
                    <Binding Path="TotalScore" StringFormat="TOTAL: {0} PUNTOS"/>
                </TextBlock.Text>
            </TextBlock>

            <Button Grid.Row="5"
                    Content="{localization:Loc Score_BackButton}"
                    Height="60"
                    Width="300"
                    HorizontalAlignment="Center"
                    Margin="0,20,0,0"
                    Command="{Binding BackCommand}"
                    Style="{StaticResource BotonRetroStyle}"/>
        </Grid>
    </Border>
</UserControl>
