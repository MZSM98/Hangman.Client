<Window x:Class="Hangman.Client.Views.CategorySelectorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:localization="clr-namespace:Hangman.Client.Localization"
             mc:Ignorable="d"
             Title="El Ahorcado - Selección de Palabra" d:DesignHeight="1080" d:DesignWidth="1920"
             WindowStartupLocation="CenterScreen" WindowState="Maximized"
             FontFamily="{StaticResource FuentePixel}">
    <Border Background="#E6F2E3D5">
        <Grid Margin="80" MaxWidth="1500" VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource ColorMaderaClara}" CornerRadius="15" Padding="25" BorderBrush="{StaticResource ColorMaderaBorde}" BorderThickness="3" Margin="0,0,0,50">
                <TextBlock Text="{localization:Loc CategorySelector_WordLabel}" FontSize="48" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource ColorTexto}"/>
            </Border>

            <WrapPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" ItemWidth="280" ItemHeight="90">
                <WrapPanel.Resources>
                    <Style TargetType="Button" BasedOn="{StaticResource BotonRetroStyle}">
                        <Setter Property="Margin" Value="15"/>
                        <Setter Property="FontSize" Value="26"/>
                    </Style>
                </WrapPanel.Resources>
                <Button Content="PERRO"/>
                <Button Content="MÉXICO" />
                <Button Content="ESPAÑA"/>
                <Button Content="GATO"/>
                <Button Content="COMPUTADORA"/>
                <Button Content="VIAJE"/>
                <Button Content="PIZZA"/>
                <Button Content="CINE"/>
                <Button Content="LIBRO"/>
            </WrapPanel>

            <TextBlock Grid.Row="2" Text="{localization:Loc CategorySelector_Hint}" FontSize="28" HorizontalAlignment="Center" Margin="0,40,0,40" Foreground="{StaticResource ColorTexto}"/>

            <Button Grid.Row="3" Content="{localization:Loc CategorySelector_ConfirmButton}" Style="{StaticResource BotonRetroStyle}" Width="450" Height="95" FontSize="32" HorizontalAlignment="Center"/>
        </Grid>
    </Border>
</Window>