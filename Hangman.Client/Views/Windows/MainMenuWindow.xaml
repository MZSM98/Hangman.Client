<Window x:Class="Hangman.Client.Views.Windows.MainMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:Hangman.Client.ViewModels"
        xmlns:userControls="clr-namespace:Hangman.Client.Views.UserControls"
        xmlns:windows="clr-namespace:Hangman.Client.Views.Windows"
        mc:Ignorable="d"
        Title="El Ahorcado - Menú Principal"
        Height="720"
        Width="1280"
        MinHeight="540"
        MinWidth="960"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        FontFamily="{StaticResource FuentePixel}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <DataTemplate DataType="{x:Type viewModels:ProfileViewModel}">
            <userControls:ProfileView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:MatchLobbyViewModel}">
            <userControls:MatchLobbyView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:MatchGameplayViewModel}">
            <userControls:MatchGameplayView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:MatchGuessViewModel}">
            <userControls:MatchGuessView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:MatchResultViewModel}">
            <userControls:MatchResultView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:ScoreViewModel}">
            <windows:ScoreView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/Assets/HangmanBackground.jpg"
                        Stretch="UniformToFill"/>
        </Grid.Background>

        <Viewbox Stretch="Uniform"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center">

            <Grid Width="1920"
                  Height="1080">

                <Border Width="800"
                        Height="754"
                        Background="#FAF3E6"
                        BorderBrush="#B58B5C"
                        BorderThickness="4"
                        CornerRadius="10"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Visibility="{Binding IsHomeVisible, Converter={StaticResource BooleanToVisibilityConverter}}">

                    <Border BorderBrush="#462A1A"
                            BorderThickness="2"
                            Margin="15,15,15,29">

                        <Grid Margin="50">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="EL AHORCADO"
                                       FontSize="70"
                                       Foreground="#462A1A"
                                       HorizontalAlignment="Center"
                                       Margin="0,20,0,0">

                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#8C5A35"
                                                      BlurRadius="0"
                                                      ShadowDepth="5"
                                                      Direction="315"
                                                      Opacity="0.7"/>
                                </TextBlock.Effect>
                            </TextBlock>

                            <StackPanel Grid.Row="2" Width="550">
                                <Button Content="PARTIDA"
                                        Height="75"
                                        Command="{Binding OpenMatchLobbyCommand}"
                                        Style="{StaticResource BotonRetroStyle}"/>

                                <Button Content="EDITAR PERFIL"
                                        Height="75"
                                        Command="{Binding OpenProfileCommand}"
                                        Style="{StaticResource BotonRetroStyle}"/>

                                <Button Content="PUNTOS"
                                        Height="75"
                                        Command="{Binding OpenScoreCommand}"
                                        Style="{StaticResource BotonRetroStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="4"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        Margin="0,0,0,10">

                                <TextBlock Text=" | "
                                           FontSize="20"
                                           FontFamily="Segoe UI"
                                           Foreground="#462A1A"
                                           VerticalAlignment="Center"
                                           Margin="10,0"/>

                                <Button Command="{Binding LogoutCommand}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Padding="0">

                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="[→ "
                                                   FontSize="22"
                                                   FontFamily="Segoe UI"
                                                   Foreground="#462A1A"
                                                   VerticalAlignment="Center"/>

                                        <TextBlock Text="Cerrar Sesión"
                                                   FontSize="20"
                                                   FontFamily="Segoe UI"
                                                   FontWeight="Medium"
                                                   Foreground="#462A1A"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Border>

                <ContentControl Content="{Binding CurrentViewModel}"/>
            </Grid>
        </Viewbox>
    </Grid>
</Window>
    
    